# Experiment 4: K-Means Clustering
# Step 1: Load necessary library
library(ggplot2)
# Step 2: Load dataset
data <- iris[, 1:4]  # using iris dataset
# Step 3: Normalize data
data_scaled <- scale(data)
# Step 4: Apply K-Means clustering
set.seed(123)
kmeans_result <- kmeans(data_scaled, centers = 3, nstart = 25)
# Step 5: Display result summary
print(kmeans_result)
# Step 6: Add cluster to data
iris$Cluster <- as.factor(kmeans_result$cluster)
# Step 7: Show cluster centers
cat("\nCluster Centers:\n")
print(kmeans_result$centers)
# Step 8: Compare species vs cluster
cat("\nSpecies vs Cluster Table:\n")
print(table(iris$Cluster, iris$Species))
# Step 9: Plot clusters
library(ggplot2)
ggplot(iris, aes(x = Petal.Length, y = Petal.Width, color = Cluster, shape = Species)) +
geom_point(size = 3) +
ggtitle("K-Means Clustering on Iris Dataset") +
theme_minimal()
